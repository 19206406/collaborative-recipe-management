{
  "JwtSettings": {
    "RsaPublicKey": "-----BEGIN PUBLIC KEY----------END PUBLIC KEY-----",
    "Issuer": "UserApi",
    "Audiences": [ "UserClient", "RecipeClient", "RatingClient" ]
  },
  "PublicRoutes": [
    "GET /api/users/{id}/basic",
    "POST /api/users/login",
    "POST /api/users/register",
    "GET /api/users/{id}/preferences",

    "GET /api/recipes",
    "POST /api/recipes",
    "GET /api/recipes/{id}",
    "PUT /api/recipes/{id}/rating",
    "GET /api/recipes/by-ingredients",
    "GET /api/recipes/get-only-recipe/{id}",
    "GET /api/recipes/search",
    "GET /api/recipes/trending",
    "GET /api/recipes/user/{userId}",

    "GET /api/ratings/recipe/{recipeId}",
    "GET /api/ratings/recipe/{recipeId}/average",
    "GET /api/ratings/user/{userId}",
    "GET /api/ratings/user/{userId}/recipe/{recipeId}",

    "POST /api/recommendations/by-ingredients",
    "GET /api/recommendations/similar/{recipeId}",
    "GET /api/recommendations/trending",
    "GET /api/recommendations/user/{userId}",

    "POST /api/notifications",
    "POST /api/notifications/rating-received"
  ], 
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
