{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning",
			"Yarp": "Warning"
		}
	},
	"ReverseProxy": {
		"Routes": {
			"users-route": {
				"ClusterId": "users-cluster",
				"AuthorizationPolicy": "authenticated",
				"Match": {
					"Path": "/api/users/{**catch-all}"
				},
				"Transforms": [
					{ "PathRemovePrefix": "/api/users" },
					{
						"RequestHeader": "X-internal-Source",
						"Set": "ApiGateway"
					}
				]
			},
			"recipes-route": {
				"ClusterId": "recipes-cluster",
				"AuthorizationPolicy": "authenticated",
				"Match": {
					"Path": "/api/recipes/{**catch-all}"
				},
				"Transforms": [
					{ "PathRemovePrefix": "/api/recipes" }
				]
			},
			"ratings-route": {
				"ClusterId": "ratings-cluster",
				"AuthorizationPolicy": "authenticated",
				"Match": {
					"Path": "/api/ratings/{**catch-all}"
				},
				"Transforms": [
					{ "PathRemovePrefix": "/api/ratings" }
				]
			},
			"recommendations-route": {
				"ClusterId": "recommendations-cluster",
				"AuthorizationPolicy": "authenticated",
				"Match": {
					"Path": "/api/recommendations/{**catch-all}"
				},
				"Transforms": [
					{ "PathRemovePrefix": "/api/recommendations" }
				]
			},
			"notifications-route": {
				"ClusterId": "notifications-cluster",
				"AuthorizationPolicy": "authenticated",
				"Match": {
					"Path": "/api/notifications/{**catch-all}"
				},
				"Transforms": [
					{ "PathRemovePrefix": "/api/notifications" }
				]
			}
		},
		"Clusters": {
			"users-cluster": {
				"LoadBalancingPolicy": "RoundRobin",
				"HealthCheck": {
					"Active": {
						"Enabled": true,
						"Interval": "00:00:30",
						"Timeout": "00:00:10",
						"Policy": "ConsecutiveFailures",
						"Path": "/health"
					}
				},
				"Destinations": {
					"users-primary": {
						"Address": "https://localhost:7296"
					}
				}
			},
			"recipes-cluster": {
				"LoadBalancingPolicy": "LeastRequests",
				"Destinations": {
					"recipes-primary": {
						"Address": "https://localhost:7037"
					}
				}
			},
			"ratings-cluster": {
				"LoadBalancingPolicy": "LeastRequests",
				"Destinations": {
					"ratings-primary": {
						"Address": "https://localhost:7154"
					}
				}
			},
			"recommendations-cluster": {
				"LoadBalancingPolicy": "LeastRequests",
				"Destinations": {
					"recommendations-primary": {
						"Address": "https://localhost:7193"
					}
				}
			},
			"notifications-cluster": {
				"LoadBalancingPolicy": "LeastRequests",
				"Destinations": {
					"notifications-primary": {
						"Address": "https://localhost:7073"
					}
				}
			}
		}
	},
	"JwtSettings": {
		"Authority": "",
		"Audience": "api-gateway",
		"ValidIssuer": "UserApi"
	}, 
	"RateLimiting": {
		"GeneralRules": [
			{
				"*Endpoint": "*",
				"Period": "1m",
				"Limit": 100
			}
		]
	}, 
	"AllowedHosts": "*"
}
